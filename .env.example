# --- Form contatto (Nodemailer) ---
# Copia questo file in ".env" e compila con credenziali reali.
# NON committare il file .env (è in .gitignore).

# Host SMTP del provider email (es. smtp.gmail.com, smtp.zoho.eu, ecc.)
EMAIL_HOST=
# Porta SMTP: 587 (STARTTLS) oppure 465 (SSL)
EMAIL_PORT=587
# Utente/login SMTP (di solito l'indirizzo email)
EMAIL_USER=
# Password SMTP o app-password
EMAIL_PASS=
# Indirizzo che riceve le richieste dal form (la casella di Gianluigi)
STUDIO_EMAIL=

# --- Database Neon + Prisma (Fase 2) ---
# Crea un progetto su https://neon.tech e copia le due connection string.
# DATABASE_URL = connessione POOLED (runtime serverless, usata dall'adapter)
#   es: postgresql://USER:PASS@ep-xxx-pooler.eu-central-1.aws.neon.tech/db?sslmode=require
DATABASE_URL=
# DIRECT_URL = connessione DIRETTA (usata da Prisma Migrate)
#   es: postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/db?sslmode=require
DIRECT_URL=

# --- Auth (Fase 2) ---
# Segreto per firmare i JWT (stringa lunga e casuale)
JWT_SECRET=
# Base URL dell'app, per i link d'invito "imposta password"
APP_URL=http://localhost:5173

# --- Seed admin (Fase 2) ---
# Credenziali del primo account admin (Gianluigi), usate da `prisma db seed`
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Stripe Checkout (Fase 3C) ---
# Usa prima le chiavi TEST del tuo account Stripe.
STRIPE_SECRET_KEY=
# Webhook signing secret: Dashboard Stripe → Developers → Webhooks
# Endpoint: https://gianluigi-pt.vercel.app/api/payments/webhook
STRIPE_WEBHOOK_SECRET=
