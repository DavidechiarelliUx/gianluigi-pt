// Schema Prisma — Gianluigi PT
// Fase 2: app allenamenti · Fase 3: business online (live, pagamenti)
// Fase 4: abbonamenti ricorrenti Stripe

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL gestite in prisma.config.ts (Prisma 7) e via adapter Neon a runtime
}

// ─────────────────────────────────────────
// ENUMS — Fase 2
// ─────────────────────────────────────────

enum Role {
  admin
  client
}

enum WorkoutStatus {
  active   // scheda attiva principale (max 1 per cliente)
  archived // scheda storica, consultabile
}

enum SessionStatus {
  in_progress
  completed
}

// ─────────────────────────────────────────
// ENUMS — Fase 3
// ─────────────────────────────────────────

enum ProductType {
  session_solo  // sessione 1:1 singola
  session_group // sessione di gruppo singola
  package       // pacchetto sessioni prepagato
}

enum OrderStatus {
  pending  // checkout aperto, non ancora pagato
  paid     // pagamento confermato da Stripe webhook
  failed   // pagamento fallito / scaduto
  refunded // rimborsato
}

enum LiveSessionType {
  solo  // 1:1 PT ↔ cliente
  group // classe / sessione di gruppo
}

enum LiveSessionStatus {
  scheduled // programmata, prenotabile
  live      // in corso
  completed // conclusa
  cancelled // annullata
}

enum BookingStatus {
  pending   // prenotato, in attesa di pagamento (se richiesto)
  confirmed // confermato (pagato o gratuito)
  cancelled // cancellato da admin o cliente
}

// ─────────────────────────────────────────
// ENUMS — Fase 4: abbonamenti
// ─────────────────────────────────────────

/// Livello di accesso concesso da un prodotto o abbonamento.
enum AccessLevel {
  none     // nessun accesso
  app      // app + schede
  live     // solo live
  app_live // app + schede + live
  premium  // tutto (app + live + 1:1)
}

/// Intervallo di fatturazione del prodotto.
enum BillingInterval {
  one_time // pagamento singolo
  month    // abbonamento mensile
  year     // abbonamento annuale
}

// ─────────────────────────────────────────
// MODELLI — Fase 2
// ─────────────────────────────────────────

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String?        // null finché il cliente non imposta la password
  role             Role           @default(client)
  fullName         String
  inviteToken      String?        @unique // token monouso "imposta password"
  inviteExpires    DateTime?
  stripeCustomerId String?        // Stripe Customer ID (fase 4)
  client           Client?
  orders           Order[]        // Fase 3
  subscriptions    Subscription[] // Fase 4
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Client {
  id              String           @id @default(uuid())
  user            User             @relation(fields: [userId], references: [id])
  userId          String           @unique
  phone           String?
  goal            String?
  notes           String?
  workouts        Workout[]
  workoutSessions WorkoutSession[]
  bookings        Booking[]        // Fase 3
  targetedLiveSessions LiveSession[] @relation("TargetedLiveSessions")
  liveCredits     LiveCreditLedger[]
  metrics         ClientMetric[]
  coachMessages   CoachMessage[]
  accessDisabledAt DateTime?
  accessDisabledReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?        // soft delete (GDPR)
}

model Workout {
  id          String           @id @default(uuid())
  client      Client           @relation(fields: [clientId], references: [id])
  clientId    String
  title       String
  description String?
  status      WorkoutStatus    @default(active)
  days        WorkoutDay[]
  sessions    WorkoutSession[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  archivedAt  DateTime?

  @@index([clientId, status])
}

model WorkoutDay {
  id        String        @id @default(uuid())
  workout   Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId String
  label     String        // "Giorno A · Push"
  order     Int           @default(0)
  items     WorkoutItem[]
}

model Exercise {
  id           String        @id @default(uuid())
  name         String        @unique
  muscleGroup  String?
  defaultNotes String?
  videoUrl     String?
  items        WorkoutItem[]
}

model WorkoutItem {
  id           String     @id @default(uuid())
  day          WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  workoutDayId String
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])
  exerciseId   String
  sets         Int
  reps         String     // "8", "8-10", "cedimento"
  restSeconds  Int?
  notes        String?
  order        Int        @default(0)
}

model WorkoutTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  days        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkoutSession {
  id                 String           @id @default(uuid())
  client             Client           @relation(fields: [clientId], references: [id])
  clientId           String
  workout            Workout          @relation(fields: [workoutId], references: [id])
  workoutId          String
  workoutDayId       String?          // giorno svolto
  date               DateTime         @default(now())
  status             SessionStatus    @default(in_progress)
  feedbackDifficulty Int?             // RPE complessivo 1-10
  feedbackNotes      String?
  itemLogs           WorkoutItemLog[]
  createdAt          DateTime         @default(now())

  @@index([clientId, date])
}

model WorkoutItemLog {
  id                  String         @id @default(uuid())
  session             WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId           String
  workoutItemId       String         // riferimento alla riga di scheda
  completed           Boolean        @default(false)
  loadUsed            String?        // "60kg", "elastico medio"
  repsDone            String?
  perceivedDifficulty Int?           // RPE per esercizio 1-10
  notes               String?
}

// ─────────────────────────────────────────
// MODELLI — Fase 3
// ─────────────────────────────────────────

/// Prodotto/pacchetto acquistabile.
model Product {
  id              String          @id @default(uuid())
  name            String          @unique
  description     String?
  priceCents      Int             // prezzo in centesimi (es. 5000 = €50,00)
  currency        String          @default("eur")
  type            ProductType
  sessionsQty     Int?            // per pacchetti: quante sessioni include
  discountPercent Int             @default(0)
  discountTiers   Json?
  features        Json?
  badgeLabel      String?
  sortOrder       Int             @default(0)
  active          Boolean         @default(true)
  // Fase 4 — abbonamenti
  accessLevel     AccessLevel     @default(app)
  billingInterval BillingInterval @default(one_time)
  stripePriceId   String?         // Stripe Price ID (opzionale, per riutilizzo)
  orders          Order[]
  liveSessions    LiveSession[]
  subscriptions   Subscription[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

/// Ordine di acquisto — creato al checkout, aggiornato dal webhook Stripe.
model Order {
  id               String      @id @default(uuid())
  user             User?       @relation(fields: [userId], references: [id])
  userId           String?
  product          Product     @relation(fields: [productId], references: [id])
  productId        String
  status           OrderStatus @default(pending)
  amountCents      Int         // copia del prezzo al momento dell'acquisto
  currency         String      @default("eur")
  quantity         Int         @default(1)
  sessionsQty      Int?
  customerEmail    String
  customerName     String
  customerPhone    String?
  stripeCustomerId String?
  stripeSessionId  String?     @unique // Stripe Checkout Session ID
  stripePaymentId  String?     // Stripe PaymentIntent ID (one-time)
  inviteSentAt     DateTime?
  liveCreditsGrantedAt DateTime?
  bookings         Booking[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([userId, status])
  @@index([customerEmail])
  @@index([stripeSessionId])
}

/// Abbonamento ricorrente Stripe — creato/aggiornato dai webhook subscription.
model Subscription {
  id                   String      @id @default(uuid())
  user                 User        @relation(fields: [userId], references: [id])
  userId               String
  product              Product?    @relation(fields: [productId], references: [id])
  productId            String?
  stripeSubscriptionId String      @unique
  stripePriceId        String?
  stripeCustomerId     String?
  /// Stato Stripe: active | trialing | past_due | unpaid | canceled | incomplete
  status               String
  accessLevel          AccessLevel @default(app)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([userId, status])
  @@index([stripeSubscriptionId])
}

/// Sessione live (1:1 o gruppo) creata dall'admin.
model LiveSession {
  id          String            @id @default(uuid())
  title       String
  type        LiveSessionType   @default(solo)
  status      LiveSessionStatus @default(scheduled)
  scheduledAt DateTime          // data e ora della sessione
  durationMin Int               @default(60)
  maxSlots    Int               @default(1)  // 1 per 1:1, N per gruppo
  product     Product?          @relation(fields: [productId], references: [id])
  productId   String?           // Product collegato (null = sessione gratuita/interna)
  targetClient Client?           @relation("TargetedLiveSessions", fields: [targetClientId], references: [id])
  targetClientId String?         // se presente, la live è visibile solo a quel cliente
  videoLink   String?           // link Zoom/Meet manuale
  notes       String?           // note interne del PT
  bookings    Booking[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([scheduledAt, status])
  @@index([targetClientId])
}

/// Prenotazione di un cliente per una sessione live.
model Booking {
  id            String        @id @default(uuid())
  liveSession   LiveSession   @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  liveSessionId String
  client        Client        @relation(fields: [clientId], references: [id])
  clientId      String
  status        BookingStatus @default(confirmed)
  order         Order?        @relation(fields: [orderId], references: [id])
  orderId       String?       // Order collegato se prenotazione a pagamento
  createdAt     DateTime      @default(now())

  @@unique([liveSessionId, clientId]) // un cliente non prenota due volte la stessa sessione
  @@index([clientId])
  @@index([liveSessionId])
}

/// Movimenti dei crediti live disponibili nell'account cliente.
model LiveCreditLedger {
  id        String   @id @default(uuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  orderId   String?
  bookingId String?
  externalRef String? @unique
  amount    Int      // positivo = accredito, negativo = consumo
  reason    String   // purchase | admin_grant | booking | booking_cancelled
  note      String?
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([orderId])
  @@index([bookingId])
}

/// Misure e check-in inseriti dal cliente.
model ClientMetric {
  id        String   @id @default(uuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  date      DateTime @default(now())
  weightKg  Float?
  waistCm   Float?
  chestCm   Float?
  hipsCm    Float?
  photoUrl  String?
  notes     String?
  createdAt DateTime @default(now())

  @@index([clientId, date])
}

/// Messaggi/richieste del cliente verso il coach.
model CoachMessage {
  id        String   @id @default(uuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  subject   String
  message   String
  senderRole String  @default("client") // client | admin
  status    String   @default("open")
  createdAt DateTime @default(now())
  readAt    DateTime?
  resolvedAt DateTime?
  hiddenAt  DateTime?

  @@index([clientId, createdAt])
  @@index([status, hiddenAt])
}
